<?xml version="1.0" encoding="UTF-8"?>
<pnml>
  <net id="net1" type="http://www.pnml.org/version-2009/grammar/ptnet">

    <!-- Places -->
    <place id="p_start"><initialMarking><text>1</text></initialMarking></place>
    <place id="p_1"></place>
    <place id="p_2"></place>
    <place id="p_3"> </place>
    <place id="p_end"> </place>

    <!-- Transitions -->
    <transition id="t_create_invoice"></transition>
    <transition id="t_sign_invoice"></transition>
    <transition id="t_stamp_invoice"></transition>
    <transition id="t_send_invoice"></transition>

    <!-- Arcs -->
    <arc id="a1" source="p_start" target="t_create_invoice"/>
    <arc id="a2" source="t_create_invoice" target="p_1"/>
    <arc id="a3" source="p_1" target="t_sign_invoice"/>
    <arc id="a4" source="t_sign_invoice" target="p_2"/>
    <arc id="a5" source="p_2" target="t_stamp_invoice"/>
    <arc id="a6" source="t_stamp_invoice" target="p_3"/>
    <arc id="a7" source="p_3" target="t_send_invoice"/>
    <arc id="a8" source="t_send_invoice" target="p_end"/>

    <!-- Roles Definition -->
    <toolspecific tool="nl.rug.ds.bpm.ptnet" version="1.0">
      <process>
        <roles>
          <role id="Alice">
            <name>Alice</name>
          </role>
          <role id="Bob">
            <name>Bob</name>
          </role>
        </roles>
        <groups/>
        <variables/>
      </process>
    </toolspecific>

  </net>
</pnml>
